# ============================================
# Poker Server Modern - Environment Variables
# ============================================
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# DO NOT COMMIT .env TO VERSION CONTROL

# ============================================
# Database Configuration (REQUIRED)
# ============================================
# PostgreSQL connection string
# CHANGE THE PASSWORD FROM 'postgres' IN PRODUCTION!
DATABASE_URL="postgresql://postgres:YOUR_SECURE_PASSWORD@localhost:5432/poker?schema=public"

# ============================================
# Redis Configuration (REQUIRED)
# ============================================
REDIS_URL="redis://localhost:6379"

# ============================================
# JWT Configuration (REQUIRED)
# ============================================
# MUST be at least 32 characters long
# CHANGE THESE IN PRODUCTION!
JWT_SECRET="YOUR_JWT_SECRET_AT_LEAST_32_CHARACTERS_LONG"
JWT_REFRESH_SECRET="YOUR_JWT_REFRESH_SECRET_AT_LEAST_32_CHARACTERS_LONG"

# Token expiration (optional, defaults shown)
# ACCESS_TOKEN_MAX_AGE="1h"
# REFRESH_TOKEN_MAX_AGE="7d"

# ============================================
# Server Configuration (OPTIONAL)
# ============================================
NODE_ENV="development"
PORT=3000
LOG_LEVEL="debug"

# ============================================
# CORS Configuration (OPTIONAL)
# ============================================
# Comma-separated list of allowed origins
CORS_ORIGIN="http://localhost:5173,http://localhost:3000"

# ============================================
# Security (PRODUCTION REQUIRED)
# ============================================
# Set to "true" in production
# PRODUCTION_MODE="true"

# Snapshot secret for game state verification (at least 32 chars)
SNAPSHOT_SECRET="YOUR_SNAPSHOT_SECRET_AT_LEAST_32_CHARACTERS"

# ============================================
# Docker Deployment (for docker-compose)
# ============================================
# These are used by docker-compose.yml
# POSTGRES_PASSWORD="YOUR_SECURE_DB_PASSWORD"
# POSTGRES_DB="poker"
